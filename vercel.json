{
  "version": 2,
  "routes": [
    { "src": "/liff", "dest": "/liff.html" },
    { "src": "/api/auth/callback", "dest": "/api/auth.js" },
    { "src": "/api/auth", "dest": "/api/auth.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/api/bookmarks/update", "dest": "/api/bookmarks/update.js" },
    { "src": "/api/bookmarks", "dest": "/api/bookmarks.js" },
    { "src": "/api/todos/([^/]+)", "dest": "/api/todos.js" },
    { "src": "/api/todos", "dest": "/api/todos.js" },
    { "src": "/api/files", "dest": "/api/files.js" },
    { "src": "/api/categories", "dest": "/api/categories.js" },
    { "src": "/api/og", "dest": "/api/og.js" },
    { "src": "/api/thumb", "dest": "/api/thumb.js" },
    { "src": "/api/setup-richmenu", "dest": "/api/setup-richmenu.js" },
    { "src": "/api/cron/remind", "dest": "/api/cron/remind.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/remind",
      "schedule": "0 1 * * *"
    }
  ]
}
